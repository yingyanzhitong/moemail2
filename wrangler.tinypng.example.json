{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tinypng-pool-worker",
  "main": "workers/tinypng-pool.ts",
  "compatibility_date": "2024-03-20",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "triggers": {
    "crons": [
      "* * * * *"
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "migrations_dir": "drizzle",
      "database_name": "moemail",
      "database_id": "9dd80929-206e-4132-91a0-e22cfb9106b1"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SITE_CONFIG",
      "id": "${KV_NAMESPACE_ID}"
    }
  ],
  "services": [
    {
      "binding": "TINYPNG_REGISTRAR_APAC",
      "service": "tinypng-pool-registrar-apac"
    },
    {
      "binding": "TINYPNG_REGISTRAR_AMERICAS",
      "service": "tinypng-pool-registrar-americas"
    },
    {
      "binding": "TINYPNG_REGISTRAR_EUROPE",
      "service": "tinypng-pool-registrar-europe"
    }
  ],
  "vars": {
      "EMAIL_DOMAIN": "tinypng-token.site"
  }
}
