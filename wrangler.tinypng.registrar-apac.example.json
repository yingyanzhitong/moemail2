{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tinypng-pool-registrar-apac",
  "main": "workers/tinypng-pool-registrar.ts",
  "compatibility_date": "2026-07-17",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": false,
  "placement": {
    "region": "aws:ap-southeast-1"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "migrations_dir": "drizzle",
      "database_name": "moemail",
      "database_id": "${DATABASE_ID}"
    }
  ],
  "vars": {
    "WORKER_ID": "registrar-apac",
    "WORKER_NAME": "亚太注册节点",
    "WORKER_REGION": "aws:ap-southeast-1"
  }
}
